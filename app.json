{
  "expo": {
    "name": "Seen?",
    "slug": "have-you-seen",
    "version": "1.0.0",
    "scheme": "have-you-seen",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "bundleIdentifier": "com.haveyouseen.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.haveyouseen.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0A84FF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Seen? to use the camera to scan QR codes for adding friends."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5e00c4e8-35bd-4f33-a23f-57e2d75841e8"
      }
    }
  }
}
